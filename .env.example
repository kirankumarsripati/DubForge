# DubForge Environment Variables
# Copy this file to .env and adjust values as needed.

# Application environment
NODE_ENV=development

# Logging level: debug | info | warn | error
DUBFORGE_LOG_LEVEL=info

# Enable Electron DevTools in development
DUBFORGE_DEV_TOOLS=false

# Default output folder for localized videos
DUBFORGE_OUTPUT_DIR=

# Python virtual environment path (optional)
DUBFORGE_PYTHON_VENV=
