{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/src/*"],
      "@dubforge/shared": ["../../packages/shared/src"],
      "@dubforge/types": ["../../packages/types/src"],
      "@dubforge/ui": ["../../packages/ui/src"],
      "@dubforge/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "electron.vite.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "playwright.config.ts"
  ]
}
