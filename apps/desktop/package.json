{
  "name": "@dubforge/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "DubForge desktop application",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "pnpm rebuild:electron && env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "pnpm rebuild:electron && env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "postinstall": "node ./node_modules/electron/install.js",
    "rebuild:electron": "electron-rebuild --force --only better-sqlite3",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "package": "pnpm rebuild:electron && electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@dubforge/assets": "workspace:*",
    "@dubforge/job-config": "workspace:*",
    "@dubforge/media": "workspace:*",
    "@dubforge/pipeline": "workspace:*",
    "@dubforge/platform-artifact": "workspace:*",
    "@dubforge/platform-events": "workspace:*",
    "@dubforge/platform-runtime": "workspace:*",
    "@dubforge/shared": "workspace:*",
    "@dubforge/types": "workspace:*",
    "@dubforge/ui": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "framer-motion": "^12.16.0",
    "lucide-react": "^0.513.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "@electron/rebuild": "^4.2.0",
    "electron-vite": "^3.1.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.dubforge.app",
    "productName": "DubForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../packages/providers/dist/assets",
        "to": "asset-registry",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.video",
      "darkModeSupport": true
    }
  }
}
