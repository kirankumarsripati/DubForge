{
  "name": "@dubforge/providers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./assets/registry.json": {
      "import": "./dist/assets/registry.json",
      "require": "./dist/assets/registry.json",
      "default": "./dist/assets/registry.json"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -R src/assets dist/",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@dubforge/job-config": "workspace:*",
    "@dubforge/types": "workspace:*",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
